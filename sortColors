class Solution:
    def sortColors(self, nums: list[int]) -> None: 
        # three pointer problem
        left = 0 # left pointer
        mid = 0 # mid pointer
        right = len(nums)-1 # right pointer

        while mid <= right: 
            if nums[mid] == 0:
                nums[left],nums[mid] = nums[mid],nums[left]
                left += 1 
                mid += 1
            elif nums[mid] == 1:
                mid += 1 
            else: 
                nums[mid],nums[right] = nums[right],nums[mid]
                right -= 1
        
        
