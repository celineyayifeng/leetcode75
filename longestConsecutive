class Solution:
    def longestConsecutive(self, nums: List[int]) -> int:

        nums = set(nums) 
        best = 0
        for i in nums: 
            if i - 1 not in nums: # exclude left neighbor
                y = i + 1 # check right neighbor
                while y in nums: # if right neighbor is present
                    y += 1 # increase right neighbor by one 
                best = max(best, y - i) # compare prev max with current res
        return best
