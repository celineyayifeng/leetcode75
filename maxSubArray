class Solution:
    def maxSubArray(self, nums: List[int]) -> int:
        res = nums[0] #first value
        total = 0 

        for n in nums:
            if total < 0:
                total = 0 
            
            total += n # add the nth value 
            res = max(res, total) # take bigger of current or prev value
        
        return res 
